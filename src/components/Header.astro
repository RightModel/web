---
import { navLinks, siteTitle } from "@/lib/site";
---

<header class="border-b" style="border-color: var(--color-border-muted);">
  <div class="page-shell flex items-center justify-between gap-6 py-4">
    <a class="flex items-center gap-3 text-lg font-semibold no-underline" href="/" style="color: var(--color-fg-default);">
      <span
        aria-hidden="true"
        class="inline-flex h-8 w-8 items-center justify-center rounded-[10px] border text-sm font-semibold"
        style="border-color: var(--color-accent); background: var(--color-accent-subtle); color: var(--color-accent);"
      >
        rm
      </span>
      <span>{siteTitle}</span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-4 text-sm font-medium">
        {navLinks.map((link) => (
          <li>
            <a class="link-quiet" href={link.href}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
