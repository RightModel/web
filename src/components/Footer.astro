---
import { footerLinks, precomputedAI } from "@/lib/site";
import { formatDate } from "@/lib/format";

interface Props {
  pricingDate: string;
}

const { pricingDate } = Astro.props;
---

<footer class="mt-16 border-t py-10" style="border-color: var(--color-border-muted);">
  <div class="page-shell grid gap-8 text-sm md:grid-cols-3">
    <div class="space-y-2">
      <p>
      Built by <a href="https://regnard.raquedan.com">Regnard Raquedan</a>. Free and open.
      <a href="https://github.com/rightmodel/web">Contribute on GitHub</a>.
      </p>
      <p>A worked example of the <a href={precomputedAI.url}>{precomputedAI.name}</a> design pattern.</p>
    </div>

    <div class="space-y-2">
      {footerLinks.primary.map((link) => (
        <p>
          <a class="link-quiet" href={link.href}>{link.label}</a>
        </p>
      ))}
    </div>

    <div class="space-y-2 text-muted">
      {footerLinks.legal.map((link) => (
        <p>
          <a class="link-quiet" href={link.href}>{link.label}</a>
        </p>
      ))}
      <p>Pricing data last refreshed: {formatDate(pricingDate)}</p>
    </div>
  </div>
</footer>
