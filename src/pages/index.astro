---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getExplanationCache, getPricingCache } from "@/lib/data";
import { precomputedAI, providerOptions } from "@/lib/site";
import { commonTaskSlugs } from "@/lib/tasks";

const rules = (await getCollection("rules")).map((entry) => entry.data);
const tasks = (await getCollection("tasks")).map((entry) => entry.data);
const pricing = getPricingCache();
const explanations = getExplanationCache();
const deepAnalysisEndpoint = import.meta.env.PUBLIC_DEEP_ANALYSIS_ENDPOINT || "/api/deep-analysis";
const commonTasks = commonTaskSlugs
  .map((slug) => tasks.find((entry) => entry.slug === slug))
  .filter((task): task is (typeof tasks)[number] => Boolean(task));
---

<BaseLayout title="Best AI model for your coding task — free model picker" path="/" pageClass="pt-10 sm:pt-14">
  <div data-home-app class="home-stage">
    <section class="space-y-8">
      <section class="max-w-3xl space-y-4">
        <h1 class="text-[2.5rem] font-semibold leading-[1.05] tracking-tight text-[color:var(--color-fg-default)] sm:text-[3.4rem]">
          Find the best AI model for the coding task in front of you.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--color-fg-muted)]">
          Paste a real developer task. rightmodel recommends the cheapest model tier that still fits
          the reasoning load, with current pricing and no signup.
        </p>
        <p class="flex flex-wrap items-center gap-4 text-sm text-[color:var(--color-fg-muted)]">
          <a class="link-quiet" href="/for">Browse task pages</a>
          <a class="link-quiet" href="/models">See covered models</a>
          <a class="link-quiet" href="/methodology">Read the methodology</a>
        </p>
      </section>

      <div class="home-input-shell">
        <label class="rm-visually-hidden" for="task-input">Task description</label>
        <textarea
          id="task-input"
          data-task-input
          rows="3"
          maxlength="500"
          class="home-input"
          placeholder="what are you about to build?"
        ></textarea>
      </div>

      <section class="home-provider-shell" aria-labelledby="current-provider-heading">
        <div class="home-provider-meta">
          <h2 id="current-provider-heading" class="home-provider-label">Current provider</h2>
          <p class="home-provider-note">Use Any if the provider is still open.</p>
        </div>

        <div class="home-provider-row" role="group" aria-label="Current provider">
          {providerOptions.map((option) => (
            <button
              data-provider={option.value}
              data-active={option.value === "all" ? "true" : "false"}
              class="button-chip"
              type="button"
              aria-pressed={option.value === "all" ? "true" : "false"}
            >
              {option.label}
            </button>
          ))}
        </div>
      </section>

      <section data-output hidden class="space-y-6" aria-live="polite">
        <article data-output-card class="space-y-3">
          <h1 data-model-name class="home-answer-title"></h1>
          <p data-deep-badge hidden class="home-deep-badge" role="status"></p>
          <p data-unsure-badge hidden class="home-unsure-badge" role="status"></p>
          <p data-overkill-note class="home-answer-subtitle"></p>
          <p data-cost-delta class="home-answer-cost"></p>
          <p data-short-input-note hidden class="home-inline-note"></p>
          <p data-provider-constraint hidden class="home-inline-note"></p>
          <p data-stale-pricing hidden class="home-inline-note home-inline-note--warning"></p>
        </article>

        <section data-secondary-controls hidden class="space-y-4">
          <details data-why-panel class="panel p-5 sm:p-6">
            <summary class="link-quiet cursor-pointer text-sm">Why -&gt;</summary>
            <div class="mt-4 space-y-5">
              <p data-why-text class="text-sm leading-6 text-[color:var(--color-fg-default)]"></p>

              <section>
                <h2 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Cost breakdown</h2>
                <div class="mt-3 overflow-x-auto">
                  <table class="rm-table">
                    <thead>
                      <tr>
                        <th>Model</th>
                        <th>Provider</th>
                        <th>Tier</th>
                        <th>Input cost</th>
                        <th>Output cost</th>
                        <th>Est. / 1k calls</th>
                      </tr>
                    </thead>
                    <tbody data-breakdown></tbody>
                  </table>
                </div>
              </section>

              <section>
                <h2 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Matched signals</h2>
                <ul data-signals class="mt-2 list-disc pl-5 text-sm text-muted"></ul>
              </section>

              <section class="text-sm text-muted">
                <h2 class="font-semibold text-[color:var(--color-fg-default)]">Sources</h2>
                <ul class="mt-2 list-disc pl-5">
                  <li>Any uses a curated shortlist from Anthropic, Google and OpenAI.</li>
                  <li>Model pricing: OpenRouter model catalog, retrieved <span data-sources-date></span>.</li>
                  <li>
                    Classification: rightmodel ruleset v2, open source under MIT and a worked example of the
                    <a href={precomputedAI.url}>Precomputed AI</a> design pattern.
                  </li>
                  <li>Costs are estimates based on average prompt and completion sizes.</li>
                </ul>
              </section>
            </div>
          </details>

          <div class="home-secondary-row">
            <div class="flex items-center gap-3">
              <button data-copy-link type="button" class="button-secondary">
                Copy link
              </button>
              <p data-copy-status aria-live="polite" class="text-sm text-muted"></p>
            </div>
          </div>

          <section data-deep-prompt hidden class="subtle-panel p-5 sm:p-6">
            <div data-deep-progress hidden class="mb-4 h-px w-full overflow-hidden bg-[color:var(--color-bg-muted)]">
              <div class="h-full w-1/2 animate-pulse bg-[color:var(--color-accent)]"></div>
            </div>
            <p data-deep-message class="text-sm text-[color:var(--color-fg-default)]">
              Not sure? Run deep analysis. This uses about 500 tokens (~$0.00005) before it fires.
            </p>
            <div class="mt-3 flex flex-wrap items-center gap-3">
              <button data-deep-run type="button" class="button-primary">
                Run deep analysis
              </button>
              <button data-deep-cancel type="button" class="link-quiet text-sm">
                Cancel
              </button>
            </div>
          </section>
        </section>
      </section>
    </section>

    <section class="home-common-tasks">
      <div class="mb-5 flex items-center justify-between gap-4">
        <h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--color-fg-muted)]">Common tasks</h2>
        <a class="link-quiet text-sm" href="/for">Browse all task pages</a>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {commonTasks.map((task) => (
          <a href={`/for/${task.slug}`} class="interactive-panel block p-5 text-[color:var(--color-fg-default)] no-underline">
            <h3 class="text-base font-semibold leading-6 tracking-tight">{task.title}</h3>
            <p class="mt-2 text-sm text-muted">{task.description}</p>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script
    is:inline
    id="rm-home-data"
    type="application/json"
    set:html={JSON.stringify({ rules, pricing, explanations, deepAnalysisEndpoint })}
  />
  <script>
    import { setupHomePage } from "../lib/home-page";

    const dataElement = document.getElementById("rm-home-data");
    const payload = dataElement?.textContent ? JSON.parse(dataElement.textContent) : null;

    if (payload) {
      setupHomePage({
        rules: payload.rules,
        pricing: payload.pricing,
        explanations: payload.explanations,
        deepAnalysisEndpoint: payload.deepAnalysisEndpoint
      });
    }
  </script>
</BaseLayout>
