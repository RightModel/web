---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getExplanationCache, getPricingCache } from "@/lib/data";
import { placeholderExamples, providerOptions } from "@/lib/site";
import { commonTaskSlugs } from "@/lib/tasks";

const rules = (await getCollection("rules")).map((entry) => entry.data);
const tasks = (await getCollection("tasks")).map((entry) => entry.data);
const pricing = getPricingCache();
const explanations = getExplanationCache();
const deepAnalysisEndpoint = import.meta.env.PUBLIC_DEEP_ANALYSIS_ENDPOINT || "";
const commonTasks = commonTaskSlugs
  .map((slug) => tasks.find((entry) => entry.slug === slug))
  .filter((task): task is (typeof tasks)[number] => Boolean(task));
---

<BaseLayout path="/" pageClass="pt-10">
  <section class="space-y-4">
    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-[color:var(--color-fg-muted)]">
      Use the right model. Not the expensive one by default.
    </p>
    <h1 class="max-w-[12ch] text-[2.5rem] font-semibold leading-[1.1] text-[color:var(--color-fg-default)]">
      Use the right model.
    </h1>
    <p class="max-w-[42rem] text-base text-[color:var(--color-fg-muted)]">
      Paste your task. Get a model recommendation in two seconds. Free, no account required.
    </p>
  </section>

  <section data-home-app class="mt-8 space-y-6">
    <div class="rm-panel p-4 sm:p-5">
      <label class="rm-visually-hidden" for="task-input">Task description</label>
      <textarea
        id="task-input"
        data-task-input
        rows="2"
        maxlength="500"
        class="min-h-[5.5rem] w-full resize-none rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg)] px-4 py-3 text-lg text-[color:var(--color-fg-default)] placeholder:text-[color:var(--color-fg-subtle)]"
        placeholder={placeholderExamples[0]}
      ></textarea>

      <div class="mt-4 flex flex-wrap gap-2" role="group" aria-label="Provider filter">
        {providerOptions.map((option) => (
          <button
            data-provider={option.value}
            data-active={option.value === "all" ? "true" : "false"}
            class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-2 text-sm font-medium text-[color:var(--color-fg-default)] transition data-[active=true]:border-[color:var(--color-accent)] data-[active=true]:bg-[color:var(--color-accent-subtle)] data-[active=true]:text-[color:var(--color-accent)]"
            type="button"
            aria-pressed={option.value === "all" ? "true" : "false"}
          >
            {option.label}
          </button>
        ))}
      </div>
    </div>

    <div data-empty-state class="rm-panel p-5 text-sm text-[color:var(--color-fg-muted)]">
      Start typing to get a recommendation.
    </div>

    <section data-output hidden class="space-y-4">
      <article
        data-output-card
        class="rm-panel border-l-4 border-l-[color:var(--color-accent)] p-5"
      >
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="space-y-2">
            <h2 data-model-name class="text-[2.5rem] font-semibold leading-[1.1] text-[color:var(--color-fg-default)]"></h2>
            <div class="flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-fg-muted)]">
              <span data-model-provider class="rounded-full bg-[color:var(--color-bg-subtle)] px-2 py-1"></span>
              <code data-model-slug class="rm-code text-sm"></code>
            </div>
          </div>
          <button
            data-copy-link
            type="button"
            class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-2 text-sm font-medium text-[color:var(--color-fg-default)]"
          >
            Copy link
          </button>
        </div>

        <p data-overkill-note class="mt-4 text-base text-[color:var(--color-fg-muted)]"></p>
        <p data-cost-delta class="rm-code mt-2 text-sm text-[color:var(--color-success)]"></p>
        <p data-short-input-note hidden class="mt-3 text-sm text-[color:var(--color-fg-muted)]"></p>
        <p data-provider-constraint hidden class="mt-2 text-sm text-[color:var(--color-fg-muted)]"></p>
        <p data-stale-pricing hidden class="mt-2 text-sm text-[color:var(--color-warning)]"></p>
        <p data-copy-status aria-live="polite" class="mt-2 text-sm text-[color:var(--color-fg-muted)]"></p>
      </article>

      <details data-why-panel class="rm-panel p-5">
        <summary class="cursor-pointer text-sm font-medium text-[color:var(--color-accent)]">Why →</summary>
        <div class="mt-4 space-y-5">
          <p data-why-text class="text-sm leading-6 text-[color:var(--color-fg-default)]"></p>

          <section>
            <h3 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Cost breakdown</h3>
            <div class="mt-3 overflow-x-auto">
              <table class="rm-table">
                <thead>
                  <tr>
                    <th>Model</th>
                    <th>Provider</th>
                    <th>Tier</th>
                    <th>Input cost</th>
                    <th>Output cost</th>
                    <th>Est. / 1k calls</th>
                  </tr>
                </thead>
                <tbody data-breakdown></tbody>
              </table>
            </div>
          </section>

          <section>
            <h3 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Tier signals</h3>
            <ul data-signals class="mt-2 list-disc pl-5 text-sm text-[color:var(--color-fg-muted)]"></ul>
          </section>

          <section class="text-sm text-[color:var(--color-fg-muted)]">
            <h3 class="font-semibold text-[color:var(--color-fg-default)]">Sources</h3>
            <ul class="mt-2 list-disc pl-5">
              <li>Model pricing: provider pricing pages, retrieved <span data-sources-date></span>.</li>
              <li>Classification: rightmodel ruleset v1, open source under MIT.</li>
              <li>Costs are estimates based on average prompt and completion sizes.</li>
            </ul>
          </section>
        </div>
      </details>

      <section data-deep-prompt hidden class="rm-panel p-5">
        <div data-deep-progress hidden class="mb-4 h-px w-full overflow-hidden bg-[color:var(--color-bg-muted)]">
          <div class="h-full w-1/2 animate-pulse bg-[color:var(--color-accent)]"></div>
        </div>
        <p data-deep-message class="text-sm text-[color:var(--color-fg-default)]">
          This will use approximately 500 tokens (~$0.00005). Proceed?
        </p>
        <div class="mt-3 flex flex-wrap items-center gap-3">
          <button
            data-deep-run
            type="button"
            class="rounded-md bg-[color:var(--color-accent)] px-3 py-2 text-sm font-semibold text-white"
          >
            Run analysis
          </button>
          <button
            data-deep-cancel
            type="button"
            class="text-sm font-medium text-[color:var(--color-accent)]"
          >
            Cancel
          </button>
        </div>
      </section>
    </section>
  </section>

  <section class="mt-10 grid gap-4 md:grid-cols-3">
    <article class="rm-panel p-5">
      <h2 class="text-base font-semibold text-[color:var(--color-fg-default)]">How it works</h2>
      <p class="mt-3 text-sm text-[color:var(--color-fg-muted)]">
        The classifier matches task signals against an open ruleset, then maps the result to the covered model tiers.
        Pricing is refreshed nightly and folded into the recommendation.
      </p>
    </article>

    <article class="rm-panel p-5">
      <h2 class="text-base font-semibold text-[color:var(--color-fg-default)]">What it does not know</h2>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-[color:var(--color-fg-muted)]">
        <li>Codebase size unless you mention it</li>
        <li>Attached files and hidden system prompts</li>
        <li>Provider changes that have not reached the nightly cache yet</li>
      </ul>
    </article>

    <article class="rm-panel p-5">
      <h2 class="text-base font-semibold text-[color:var(--color-fg-default)]">Who built this</h2>
      <p class="mt-3 text-sm text-[color:var(--color-fg-muted)]">
        rightmodel is a personal project by Regnard Raquedan. More context lives on the
        <a href="/about">About page</a>.
      </p>
    </article>
  </section>

  <section class="mt-10 space-y-4">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-xl font-semibold text-[color:var(--color-fg-default)]">Common tasks</h2>
      <a class="text-sm font-medium text-[color:var(--color-accent)]" href="/models">View models</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {commonTasks.map((task) => (
        <a href={`/for/${task.slug}`} class="rm-panel block p-5 text-[color:var(--color-fg-default)] no-underline">
          <h3 class="text-base font-semibold leading-6">{task.title}</h3>
          <p class="mt-2 text-sm text-[color:var(--color-fg-muted)]">{task.description}</p>
        </a>
      ))}
    </div>
  </section>

  <script
    is:inline
    id="rm-home-data"
    type="application/json"
    set:html={JSON.stringify({ rules, pricing, explanations, placeholderExamples, deepAnalysisEndpoint })}
  />
  <script>
    import { setupHomePage } from "../lib/home-page";

    const dataElement = document.getElementById("rm-home-data");
    const payload = dataElement?.textContent ? JSON.parse(dataElement.textContent) : null;

    if (payload) {
      setupHomePage({
        rules: payload.rules,
        pricing: payload.pricing,
        explanations: payload.explanations,
        placeholders: payload.placeholderExamples,
        deepAnalysisEndpoint: payload.deepAnalysisEndpoint
      });
    }
  </script>
</BaseLayout>
