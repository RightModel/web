---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getExplanationCache, getPricingCache } from "@/lib/data";
import { placeholderExamples, providerOptions } from "@/lib/site";
import { commonTaskSlugs } from "@/lib/tasks";

const rules = (await getCollection("rules")).map((entry) => entry.data);
const tasks = (await getCollection("tasks")).map((entry) => entry.data);
const pricing = getPricingCache();
const explanations = getExplanationCache();
const deepAnalysisEndpoint = import.meta.env.PUBLIC_DEEP_ANALYSIS_ENDPOINT || "/api/deep-analysis";
const commonTasks = commonTaskSlugs
  .map((slug) => tasks.find((entry) => entry.slug === slug))
  .filter((task): task is (typeof tasks)[number] => Boolean(task));
---

<BaseLayout path="/" pageClass="py-12 lg:py-16">
  <div class="space-y-12">
    <section class="home-hero">
      <p class="insight-card-kicker">Use the right model. Not the expensive one by default.</p>
      <h1>Use the right model.</h1>
      <p>Paste your task. Get a model recommendation in two seconds. Free, no account required.</p>
    </section>

    <section data-home-app class="space-y-6">
      <div class="panel p-5 sm:p-6">
        <div class="home-filter-grid">
          <div>
            <label class="field-label" for="task-input">Describe the task</label>
            <textarea
              id="task-input"
              data-task-input
              rows="3"
              maxlength="500"
              class="w-full resize-none rounded-[6px] border px-4 py-3 text-lg"
              style="min-height: 6.5rem; border-color: var(--color-border); background: var(--color-bg);"
              placeholder={placeholderExamples[0]}
            ></textarea>
          </div>
          <p class="home-filter-note">Free, no account required.</p>
        </div>

        <div class="mt-5">
          <p class="field-label">Provider</p>
          <div class="flex flex-wrap gap-2" role="group" aria-label="Provider filter">
            {providerOptions.map((option) => (
              <button
                data-provider={option.value}
                data-active={option.value === "all" ? "true" : "false"}
                class="button-chip"
                type="button"
                aria-pressed={option.value === "all" ? "true" : "false"}
              >
                {option.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="home-results-divider" aria-live="polite">
        <div class="home-results-meta">
          <span class="home-results-label">Recommendation</span>
          <span class="home-results-count">Heuristic + deep follow-up</span>
        </div>
      </div>

      <div data-empty-state class="panel p-5 text-sm text-muted">
        Start typing to get a recommendation.
      </div>

      <section data-output hidden class="space-y-4">
        <article
          data-output-card
          class="panel border-l-4 border-l-[color:var(--color-accent)] p-5 sm:p-6"
        >
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="space-y-2">
              <p class="home-results-label">Recommended model</p>
              <h2 data-model-name class="max-w-[12ch] text-[2.4rem] font-semibold tracking-tight text-[color:var(--color-fg-default)] sm:text-[2.8rem]" style="line-height: 0.98;"></h2>
              <div class="flex flex-wrap items-center gap-3 text-sm text-muted">
                <span data-model-provider class="home-results-count"></span>
                <code data-model-slug class="rm-code text-sm"></code>
              </div>
            </div>
            <button
              data-copy-link
              type="button"
              class="button-secondary"
            >
              Copy link
            </button>
          </div>

          <p data-overkill-note class="mt-4 text-base text-muted"></p>
          <p data-cost-delta class="rm-code mt-2 text-sm text-[color:var(--color-success)]"></p>
          <p data-short-input-note hidden class="mt-3 text-sm text-muted"></p>
          <p data-provider-constraint hidden class="mt-2 text-sm text-muted"></p>
          <p data-stale-pricing hidden class="mt-2 text-sm text-[color:var(--color-warning)]"></p>
          <p data-copy-status aria-live="polite" class="mt-2 text-sm text-muted"></p>
        </article>

        <details data-why-panel class="panel p-5 sm:p-6">
          <summary class="link-quiet cursor-pointer text-sm">Why this model</summary>
          <div class="mt-4 space-y-5">
            <p data-why-text class="text-sm leading-6 text-[color:var(--color-fg-default)]"></p>

            <section>
              <h3 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Cost breakdown</h3>
              <div class="mt-3 overflow-x-auto">
                <table class="rm-table">
                  <thead>
                    <tr>
                      <th>Model</th>
                      <th>Provider</th>
                      <th>Tier</th>
                      <th>Input cost</th>
                      <th>Output cost</th>
                      <th>Est. / 1k calls</th>
                    </tr>
                  </thead>
                  <tbody data-breakdown></tbody>
                </table>
              </div>
            </section>

            <section>
              <h3 class="text-sm font-semibold text-[color:var(--color-fg-default)]">Tier signals</h3>
              <ul data-signals class="mt-2 list-disc pl-5 text-sm text-muted"></ul>
            </section>

            <section class="text-sm text-muted">
              <h3 class="font-semibold text-[color:var(--color-fg-default)]">Sources</h3>
              <ul class="mt-2 list-disc pl-5">
                <li>Model pricing: provider pricing pages, retrieved <span data-sources-date></span>.</li>
                <li>Classification: rightmodel ruleset v1, open source under MIT.</li>
                <li>Costs are estimates based on average prompt and completion sizes.</li>
              </ul>
            </section>
          </div>
        </details>

        <section data-deep-prompt hidden class="subtle-panel p-5 sm:p-6">
          <div data-deep-progress hidden class="mb-4 h-px w-full overflow-hidden bg-[color:var(--color-bg-muted)]">
            <div class="h-full w-1/2 animate-pulse bg-[color:var(--color-accent)]"></div>
          </div>
          <p data-deep-message class="text-sm text-[color:var(--color-fg-default)]">
            This will use approximately 500 tokens (~$0.00005). Proceed?
          </p>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <button
              data-deep-run
              type="button"
              class="button-primary"
            >
              Run analysis
            </button>
            <button
              data-deep-cancel
              type="button"
              class="link-quiet text-sm"
            >
              Cancel
            </button>
          </div>
        </section>
      </section>
    </section>

    <section class="home-insights">
      <div class="grid gap-8 lg:grid-cols-3">
        <section class="insight-card">
          <p class="insight-card-kicker">How it works</p>
          <h2>Rule-based classification first, pricing folded in.</h2>
          <p>
            The classifier matches task signals against an open ruleset, then maps the result to the covered model tiers.
            Pricing is refreshed nightly and folded into the recommendation.
          </p>
        </section>
        <section class="insight-card">
          <p class="insight-card-kicker">What it does not know</p>
          <h2>Useful limits, stated plainly.</h2>
          <ul>
            <li>Codebase size unless you mention it</li>
            <li>Attached files and hidden system prompts</li>
            <li>Provider changes that have not reached the nightly cache yet</li>
          </ul>
        </section>
        <section class="insight-card">
          <p class="insight-card-kicker">Who built this</p>
          <h2>Built as a focused, opinionated utility.</h2>
          <p>
            rightmodel is a personal project by Regnard Raquedan. More context lives on the
            <a href="/about">About page</a>.
          </p>
        </section>
      </div>
    </section>

    <section class="space-y-4">
      <div class="home-results-divider">
        <div class="home-results-meta">
          <span class="home-results-label">Common tasks</span>
          <a class="home-results-count no-underline" href="/models">View models</a>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {commonTasks.map((task) => (
          <a href={`/for/${task.slug}`} class="interactive-panel block p-5 text-[color:var(--color-fg-default)] no-underline">
            <h3 class="text-base font-semibold leading-6 tracking-tight">{task.title}</h3>
            <p class="mt-2 text-sm text-muted">{task.description}</p>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script
    is:inline
    id="rm-home-data"
    type="application/json"
    set:html={JSON.stringify({ rules, pricing, explanations, placeholderExamples, deepAnalysisEndpoint })}
  />
  <script>
    import { setupHomePage } from "../lib/home-page";

    const dataElement = document.getElementById("rm-home-data");
    const payload = dataElement?.textContent ? JSON.parse(dataElement.textContent) : null;

    if (payload) {
      setupHomePage({
        rules: payload.rules,
        pricing: payload.pricing,
        explanations: payload.explanations,
        placeholders: payload.placeholderExamples,
        deepAnalysisEndpoint: payload.deepAnalysisEndpoint
      });
    }
  </script>
</BaseLayout>
