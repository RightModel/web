---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPricingCache } from "@/lib/data";
import { defaultSiteUrl, pageDescriptions, precomputedAI, siteDescription, siteTitle } from "@/lib/site";
import { buildPageJsonLd, type JsonLdType } from "@/lib/seo";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  pageClass?: string;
  pageWidth?: "default" | "wide";
  titleAbsolute?: boolean;
  ogImagePath?: string;
  jsonLdType?: JsonLdType;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  showHeaderNav?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  pageClass = "",
  pageWidth = "default",
  titleAbsolute = false,
  ogImagePath = "/og.png",
  jsonLdType = "WebPage",
  jsonLd,
  showHeaderNav = path !== "/"
} = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || defaultSiteUrl;
const canonical = new URL(path, siteUrl).toString();
const pricing = getPricingCache();
const pageTitle = title ? (titleAbsolute ? title : `${title} | ${siteTitle}`) : `${siteTitle} | Use the right model.`;
const pageDescription = description || pageDescriptions[path] || siteDescription;
const imageUrl = new URL(ogImagePath, siteUrl).toString();
const verificationToken = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const gaMeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
const defaultJsonLd =
  path === "/"
    ? [
        buildPageJsonLd({
          type: "WebSite",
          title: pageTitle,
          description: pageDescription,
          canonical,
          image: imageUrl
        }),
        {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        applicationCategory: "DeveloperApplication",
        name: siteTitle,
        operatingSystem: "Web",
        url: canonical,
        description: siteDescription,
        about: {
          "@type": "Thing",
          name: precomputedAI.name,
          url: precomputedAI.url,
          description: precomputedAI.description
        },
        citation: {
          "@type": "CreativeWork",
          name: precomputedAI.citation,
          url: precomputedAI.citationUrl
        },
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD"
        },
        isBasedOn: {
          "@type": "CreativeWork",
          name: precomputedAI.citation,
          alternateName: precomputedAI.name,
          url: precomputedAI.citationUrl
        }
        }
      ]
    : [
        buildPageJsonLd({
          type: jsonLdType,
          title: pageTitle,
          description: pageDescription,
          canonical,
          image: imageUrl
        })
      ];
const jsonLdEntries = [...defaultJsonLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#4a5296" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
    <meta property="twitter:image" content={imageUrl} />
    {verificationToken && <meta name="google-site-verification" content={verificationToken} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    {jsonLdEntries.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    {gaMeasurementId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script
          is:inline
          set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){ dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', ${JSON.stringify(gaMeasurementId)});
          `}
        />
      </>
    )}
  </head>
  <body>
    <div class="progress-line" aria-hidden="true"></div>
    <Header showNav={showHeaderNav} />
    <main class:list={["rm-page", pageWidth === "wide" && "rm-page--wide", pageClass]}>
      <slot />
    </main>
    <Footer pricingDate={pricing.retrieved_at} />
  </body>
</html>
